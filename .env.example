# ─── AWS ────────────────────────────────────────────────────────────────────
# AWS region where Bedrock is available
AWS_REGION=us-east-1

# Leave blank if running on EC2 with an IAM instance profile
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Bedrock ─────────────────────────────────────────────────────────────────
# Model used by all three agents. Must have cross-region inference enabled.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ─── Storage ─────────────────────────────────────────────────────────────────
# Root path for the file system storage layer.
# Local dev: ./storage   |   EC2: /opt/ai-agents/storage
STORAGE_PATH=./storage

# ─── Memory Backend ──────────────────────────────────────────────────────────
# "local"     → LocalMemoryStore (JSON files in storage/memory/)
# "agentcore" → AgentCore Memory (future — requires EP-7 migration)
MEMORY_BACKEND=local

# ─── Agent API Ports ─────────────────────────────────────────────────────────
# Must match the VITE_*_API_URL ports in frontend/.env
CLAIMS_API_PORT=8001
UNDERWRITING_API_PORT=8002
LOAN_API_PORT=8003

# ─── Human-in-the-Loop ───────────────────────────────────────────────────────
# Seconds to wait for a human approval before expiring the workflow.
# Default: 86400 (24 hours)
APPROVAL_TIMEOUT_SECONDS=86400

# ─── Python / Windows encoding ───────────────────────────────────────────────
# Force UTF-8 for all Python I/O on Windows (avoids UnicodeEncodeError when
# libraries write emoji or non-ASCII text to stdout before setup_logging runs).
PYTHONUTF8=1

# ─── OpenTelemetry ───────────────────────────────────────────────────────────
# Disable the OTel SDK to suppress ContextVar cross-context errors that occur
# when the Strands async generator is closed while sync sub-agents are still
# holding span context tokens created in a different asyncio Context.
# Set to "false" only if you have a configured trace/metric exporter.
OTEL_SDK_DISABLED=true
